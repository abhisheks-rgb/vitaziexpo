{
  "name": "vitaziexpo",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/hooks": "^100.1.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.17.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "expo": "~56.0.8",
    "expo-blur": "~56.0.3",
    "expo-camera": "~56.0.7",
    "expo-constants": "~56.0.17",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.9",
    "expo-linear-gradient": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "i18n-js": "^4.5.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-pager-view": "8.0.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.8.3",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "start:mock": "cross-env EXPO_PUBLIC_ENV=mock expo start",
    "start:dev": "cross-env EXPO_PUBLIC_ENV=dev expo start",
    "start:prod": "cross-env EXPO_PUBLIC_ENV=prod expo start",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "build:android": "eas build -p android",
    "build:ios": "eas build -p ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint:fix && npm run format && npm run type-check",
    "analyze": "npm run lint && npm run type-check && npm run format:check",
    "clean": "rm -rf node_modules package-lock.json .expo",
    "reset": "npm run clean && npm install",
    "lint:fix:strict": "eslint . --fix --max-warnings=0",
    "lint:errors": "eslint . --quiet",
    "lint:errors:fix": "eslint . --fix --quiet",
    "lint:unused": "eslint . --rule '@typescript-eslint/no-unused-vars:error'"
  }
}
